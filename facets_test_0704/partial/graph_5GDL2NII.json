  "nodes": [
    {
      "id": "causal_mosaic:node:f94721530f5f",
      "name": "Rewetting of the area affected by the ditch",
      "entity_type": "management_intervention",
      "entity_term": "causal_mosaic:unresolved_82bd849b06",
      "state_or_change_qualifier": "occurred",
      "source_spans": [
        {
          "text": "Rewetting of the area affected by the ditch was carried out by the construction of six dams at 40 cm elevation intervals and felling of all trees (with diameter at breast height >10 cm) within 30 m."
        }
      ]
    },
    {
      "id": "causal_mosaic:node:e08b555e03ee",
      "name": "Water table level",
      "entity_type": "environmental_variable",
      "entity_term": "causal_mosaic:unresolved_9b7d966612",
      "state_or_change_qualifier": "unspecified",
      "measured_attribute": "distance separating the water table and the peat surface",
      "source_spans": [
        {
          "text": "Water table level was restored to levels similar to intact bog reference sites"
        }
      ]
    },
    {
      "id": "causal_mosaic:node:3dff50cf951e",
      "name": "Cutting trees",
      "entity_type": "management_intervention",
      "entity_term": "causal_mosaic:unresolved_de1a575a3f",
      "state_or_change_qualifier": "occurred",
      "source_spans": [
        {
          "text": "Cutting trees caused a shallower WTL",
          "start_char": 27572,
          "end_char": 27608,
          "paragraph_id": "page:7"
        }
      ]
    },
    {
      "id": "causal_mosaic:node:37b537657041",
      "name": "Trees",
      "entity_type": "taxon",
      "entity_term": "WD:Q10884",
      "state_or_change_qualifier": "present",
      "source_spans": [
        {
          "text": "Trees then continued to deepen the WTL",
          "start_char": 38005,
          "end_char": 38043,
          "paragraph_id": "page:11"
        }
      ]
    },
    {
      "id": "causal_mosaic:node:8ecbf3b10dc0",
      "name": "sulfate (SO4 2−)",
      "entity_type": "environmental_variable",
      "entity_term": "causal_mosaic:unresolved_86b5cbeabd",
      "state_or_change_qualifier": "decreased",
      "source_spans": [
        {
          "text": "The only exception was sulfate (SO4 2−), which was highest in the rewetted sites pre-rewetting (2010) and decreased post-rewetting."
        }
      ]
    },
    {
      "id": "causal_mosaic:node:664298377772",
      "name": "cover of pioneer mosses",
      "entity_type": "environmental_variable",
      "entity_term": "causal_mosaic:unresolved_834199c057",
      "state_or_change_qualifier": "unchanged",
      "source_spans": [
        {
          "text": "Five to 6 years post-rewetting, the cover of both pioneer mosses, and late successional mosses ( Sphagnum) had not changed significantly compared with pre-rewetting."
        }
      ]
    },
